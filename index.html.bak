<section id="guarantees" aria-labelledby="guarantees-heading">
  <div class="guarantees-inner">
    <div class="section-header center fade-up">
      <p class="section-label" style="color:#7dd3fc">Our Promises</p>
      <h2 class="section-title light" id="guarantees-heading">Iron-Clad Guarantees</h2>
      <p class="section-sub light">Every plumbing job across Bondi Beach and the Eastern Suburbs comes with our complete satisfaction promise, from your first call to final inspection.</p>
    </div>
    <div class="guarantees-grid">
      <div class="guarantee-card fade-up" style="animation-delay:0.05s">
        <div class="guarantee-icon-wrap">
          <!-- Magnifying glass with plus = free inspection -->
          <svg viewBox="0 0 24 24"><circle cx="10.5" cy="10.5" r="6.5"/><line x1="15.5" y1="15.5" x2="21" y2="21"/><line x1="10.5" y1="7.5" x2="10.5" y2="13.5"/><line x1="7.5" y1="10.5" x2="13.5" y2="10.5"/></svg>
        </div>
        <h3>Free Safety Inspection</h3>
        <p>Every visit includes a complimentary safety inspection of your plumbing system at no extra charge.</p>
      </div>
      <div class="guarantee-card fade-up" style="animation-delay:0.10s">
        <div class="guarantee-icon-wrap">
          <!-- Shield with checkmark = satisfaction guaranteed -->
          <svg viewBox="0 0 24 24"><path d="M12 2l7 3v6c0 4.5-3 8.5-7 10C5 19.5 2 15.5 2 11V5l10-3z"/><polyline points="8.5 12 10.5 14 15.5 9"/></svg>
        </div>
        <h3>100% Satisfaction</h3>
        <p>Not happy? We'll make it right. Your satisfaction is guaranteed or we don't get paid. Simple as that.</p>
      </div>
      <div class="guarantee-card fade-up" style="animation-delay:0.15s">
        <div class="guarantee-icon-wrap">
          <!-- Wrench/spanner = parts warranty -->
          <svg viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
        </div>
        <h3>12-Month Parts Warranty</h3>
        <p>All parts and fixtures carry a minimum 12-month warranty. Premium brands for lasting results.</p>
      </div>
      <div class="guarantee-card fade-up" style="animation-delay:0.20s">
        <div class="guarantee-icon-wrap">
          <!-- Medal/ribbon = lifetime workmanship -->
          <svg viewBox="0 0 24 24"><circle cx="12" cy="9" r="5"/><polyline points="9.2 14.5 8 22 12 19.5 16 22 14.8 14.45"/><polyline points="9.5 9 11 10.5 14.5 7"/></svg>
        </div>
        <h3>Lifetime Workmanship</h3>
        <p>Our workmanship is guaranteed for life. If it fails due to our work, we fix it. No charge, no hassle.</p>
      </div>
    </div>
  </div>
</section>


