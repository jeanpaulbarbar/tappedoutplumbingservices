  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue: #1B72BE;
      --blue-dark: #155fa0;
      --blue-light: #2389de;
      --red: #D63031;
      --red-dark: #b02020;
      --navy: #0B1E3C;
      --navy2: #0a1628;
      --white: #ffffff;
      --grey: #f4f6f9;
      --text: #404040;
      --text-muted: #6b7280;
      --radius: 8px;
      --shadow-blue: 0 4px 24px rgba(27,114,190,0.25), 0 1px 4px rgba(27,114,190,0.15);
      --shadow-card: 0 2px 16px rgba(0,0,0,0.10), 0 1px 4px rgba(0,0,0,0.06);
      --gold: #F5A623;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      color: var(--text);
      background: #ffffff;
      line-height: 1.7;
      font-size: 18px;
      overflow-x: clip;
    }

    /* ══════════════════════════════════
       TWO-TONE NAV (Dr Leak style)
    ══════════════════════════════════ */
    #navbar {
      position: relative;
      z-index: 1000;
    }

    .nav-top {
      background: var(--navy);
      border-bottom: 2px solid rgba(27,114,190,0.4);
    }
    .nav-top-inner {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 24px;
      height: 80px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      overflow: visible;
    }
    .nav-logo img {
      height: 120px;
      width: auto;
      display: block;
      filter: drop-shadow(0 2px 10px rgba(0,0,0,0.5));
      position: relative;
      z-index: 2;
    }
    .nav-top-right {
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .nav-phone-top {
      display: none;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      border: 2px solid var(--red);
      border-radius: 8px;
      padding: 9px 18px;
      transition: background 0.2s, color 0.2s;
    }
    @media(min-width:768px){ .nav-phone-top { display: flex; } }
    .nav-phone-icon { display: flex; align-items: center; justify-content: center; }
    .nav-phone-icon i { color: var(--red); font-size: 16px; transition: color 0.2s; }
    .nav-phone-num {
      font-size: 18px; font-weight: 800; letter-spacing: -0.01em;
      color: #fff; white-space: nowrap; transition: color 0.2s;
    }
    .nav-phone-top:hover { background: var(--red); }
    .nav-phone-top:hover .nav-phone-icon i { color: #fff; }
    .nav-phone-top:hover .nav-phone-num { color: #fff; }

    .btn-quote-top {
      background: var(--red);
      color: #fff;
      padding: 12px 26px;
      border-radius: 8px;
      font-size: 17px;
      font-weight: 700;
      text-decoration: none;
      white-space: nowrap;
      transition: background 0.2s, transform 0.15s;
      display: none;
    }
    @media(min-width:1024px){ .btn-quote-top { display: inline-block; } }
    .btn-quote-top:hover { background: var(--red-dark); transform: translateY(-1px); }

    #hamburger {
      display: flex;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      padding: 4px;
      background: none;
      border: none;
    }
    @media(min-width:1024px){ #hamburger { display: none; } }
    #hamburger span {
      display: block; width: 26px; height: 2px;
      background: var(--white); border-radius: 2px;
      transition: transform 0.3s, opacity 0.3s;
    }
    #hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    #hamburger.open span:nth-child(2) { opacity: 0; }
    #hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    /* Bottom nav bar - STICKY, desktop only */
    .nav-bottom {
      background: var(--blue);
      display: none;
      position: sticky;
      top: 0;
      z-index: 999;
    }
    @media(min-width:1024px){ .nav-bottom { display: block; } }
    .nav-bottom-inner {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 24px;
      height: 52px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .nav-links {
      display: flex;
      gap: 32px;
      list-style: none;
    }
    .nav-links a {
      color: rgba(255,255,255,0.92);
      text-decoration: none;
      font-size: 16px;
      font-weight: 600;
      letter-spacing: 0.01em;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--white); }
    .nav-tagline {
      font-size: 14px;
      color: rgba(255,255,255,0.75);
      font-weight: 500;
      letter-spacing: 0.03em;
    }

    /* Mobile menu */
    #mobile-menu {
      display: none;
      background: var(--navy2);
      border-top: 1px solid #1a3060;
    }
    #mobile-menu.open { display: block; }
    #mobile-menu ul { list-style: none; padding: 12px 24px 20px; }
    #mobile-menu ul li a {
      display: block; color: #d1d5db; text-decoration: none;
      font-size: 17px; font-weight: 600;
      padding: 12px 0; border-bottom: 1px solid #1a3060;
    }
    #mobile-menu ul li:last-child a { border-bottom: none; }
    #mobile-menu ul li a:hover { color: var(--blue); }

    /* ══════════════════════════════════
       HERO
    ══════════════════════════════════ */
    #hero {
      position: relative;
      min-height: 100vh;
      background: var(--navy);
      margin-top: 0;
      display: flex;
      align-items: center;
      margin-bottom: -4px;
    }
    @media(min-width:1024px){ #hero { margin-top: 0; } }

    .hero-bg {
      position: absolute; inset: 0;
      display: grid;
      grid-template-columns: 1fr 1fr 1fr 1fr;
      overflow: hidden;
    }
    .hero-bg-img {
      width: 100%; height: 100%;
      object-fit: cover; object-position: center top;
      display: block;
    }
    .hero-bg::after {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(105deg, rgba(11,30,60,0.93) 0%, rgba(11,30,60,0.82) 55%, rgba(27,114,190,0.55) 100%);
    }

    .hero-inner {
      position: relative; z-index: 2;
      max-width: 1340px; margin: 0 auto;
      padding: 80px 24px;
      display: grid;
      grid-template-columns: 1fr;
      gap: 48px; width: 100%;
    }
    @media(min-width:1100px){
      .hero-inner {
        grid-template-columns: 1fr 360px 420px;
        align-items: end;
        padding: 80px 48px 0;
        gap: 32px;
      }
    }

    .hero-rating {
      display: inline-flex; align-items: center; gap: 10px;
      background: rgba(255,255,255,0.10);
      border: 1px solid rgba(255,255,255,0.20);
      backdrop-filter: blur(8px);
      border-radius: 50px; padding: 8px 20px; margin-bottom: 24px;
    }
    .hero-rating .stars { color: #f59e0b; font-size: 18px; letter-spacing: 2px; }
    .hero-rating span { color: #fff; font-size: 15px; font-weight: 600; }

    .hero-eyebrow {
      font-size: 13px; font-weight: 700; letter-spacing: 0.15em;
      text-transform: uppercase; color: var(--gold); margin-bottom: 10px;
    }
    .hero-h1 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(52px, 7vw, 96px);
      color: var(--white); line-height: 0.95;
      letter-spacing: 0.01em; margin-bottom: 22px;
    }
    .hero-h1 .highlight { color: var(--blue); }
    .hero-h1 .sub-line {
      font-family: 'Plus Jakarta Sans', sans-serif;
      display: block; font-size: clamp(18px, 2vw, 26px);
      font-weight: 600; color: #cbd5e1;
      letter-spacing: -0.01em; line-height: 1.3;
      margin-top: 8px;
    }

    .hero-sub {
      font-size: 20px; color: #cbd5e1; line-height: 1.7;
      margin-bottom: 32px; max-width: 520px;
    }

    .hero-phone-btn {
      display: inline-flex; align-items: center; gap: 12px;
      background: var(--red); color: #fff;
      padding: 18px 36px; border-radius: 8px;
      font-size: 22px; font-weight: 700; text-decoration: none;
      letter-spacing: -0.02em;
      box-shadow: 0 8px 32px rgba(214,48,49,0.40);
      transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
      margin-bottom: 32px;
    }
    .hero-phone-btn:hover { background: var(--red-dark); transform: translateY(-2px); }
    .hero-phone-btn:active { transform: translateY(0); }

    .trust-badges { display: flex; flex-wrap: wrap; gap: 10px; }
    .trust-badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(255,255,255,0.09);
      border: 1px solid rgba(255,255,255,0.20);
      border-radius: 50px; padding: 8px 16px;
      font-size: 14px; font-weight: 600; color: #e5e7eb;
    }
    .trust-badge .dot { width: 8px; height: 8px; background: var(--blue); border-radius: 50%; flex-shrink: 0; }

    /* Mascot column */
    .hero-mascot-col {
      display: none;
      align-items: flex-end;
      justify-content: center;
    }
    @media(min-width:1100px){ .hero-mascot-col { display: flex; } }
    .hero-mascot-img {
      height: 520px; width: auto;
      object-fit: contain;
      mix-blend-mode: multiply;
      filter: drop-shadow(0 0 40px rgba(27,114,190,0.4));
      pointer-events: none;
    }

    /* Hero Contact Form */
    .hero-form-card {
      background: linear-gradient(160deg, #0B1E3C 0%, #1B72BE 100%);
      border-radius: 12px; padding: 36px 32px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.45);
      border-top: 4px solid var(--gold);
    }
    .hero-form-card h3 {
      font-size: 28px; font-weight: 800; color: #fff;
      margin-bottom: 4px; letter-spacing: -0.02em;
    }
    .hero-form-card h3::after {
      content: ''; display: block; width: 48px; height: 3px;
      background: var(--gold); margin-top: 8px; margin-bottom: 12px; border-radius: 2px;
    }
    .hero-form-card > p {
      font-size: 15px; color: rgba(255,255,255,0.75); margin-bottom: 20px;
    }
    .form-group { margin-bottom: 14px; }
    .form-group label {
      display: block; font-size: 13px; font-weight: 600;
      color: rgba(255,255,255,0.85); margin-bottom: 5px;
      text-transform: uppercase; letter-spacing: 0.06em;
    }
    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%; border: 1.5px solid #e5e7eb; border-radius: 7px;
      padding: 12px 14px; font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 16px; color: #111; background: #fafafa;
      transition: border-color 0.2s, box-shadow 0.2s; outline: none;
    }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
      border-color: var(--blue); box-shadow: 0 0 0 3px rgba(27,114,190,0.12); background: #fff;
    }
    .form-group textarea { resize: vertical; min-height: 80px; }
    .btn-submit {
      width: 100%; background: var(--red); color: #fff;
      border: none; border-radius: 8px; padding: 18px;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 19px; font-weight: 800; cursor: pointer;
      letter-spacing: -0.01em;
      transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
      box-shadow: 0 4px 20px rgba(214,48,49,0.35);
    }
    .btn-submit:hover { background: var(--red-dark); transform: translateY(-2px); }
    .btn-submit:active { transform: translateY(0); }

    /* ══════════════════════════════════
       TRUST BAR
    ══════════════════════════════════ */
    #trust-bar {
      background: var(--navy);
    }
    .trust-bar-inner {
      max-width: 1280px; margin: 0 auto; padding: 44px 24px;
      display: grid; grid-template-columns: repeat(2,1fr); gap: 32px;
    }
    @media(min-width:768px){ .trust-bar-inner { grid-template-columns: repeat(4,1fr); } }
    .trust-item { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 14px; }
    .trust-icon {
      width: 68px; height: 68px; background: var(--blue); border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 4px 20px rgba(27,114,190,0.35);
    }
    .trust-icon svg { width: 32px; height: 32px; stroke: #fff; fill: none; }
    .trust-item h4 { font-size: 18px; font-weight: 700; color: var(--white); letter-spacing: -0.01em; }
    .trust-item p { font-size: 14px; color: #9ca3af; line-height: 1.5; }

    /* ══════════════════════════════════
       SECTION HELPERS
    ══════════════════════════════════ */
    .section-label {
      font-size: 13px; font-weight: 700; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--blue); margin-bottom: 10px;
    }
    .section-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(40px, 5vw, 64px);
      color: var(--navy); letter-spacing: 0.01em;
      line-height: 1.0; margin-bottom: 16px;
    }
    .section-title.light { color: var(--white); }
    .section-sub {
      font-size: 20px; color: var(--text-muted); line-height: 1.7; max-width: 600px;
    }
    .section-sub.light { color: #9ca3af; }
    .section-header { margin-bottom: 52px; }
    .section-header.center { text-align: center; }
    .section-header.center .section-sub { margin: 0 auto; }

    /* ══════════════════════════════════
       SERVICES GRID
    ══════════════════════════════════ */
    #services {
      padding: 100px 24px;
      background: #f0f6ff;
      position: relative;
    }
    .services-container { max-width: 1280px; margin: 0 auto; }
    .services-grid {
      display: grid; grid-template-columns: 1fr; gap: 24px;
    }
    @media(min-width:640px){ .services-grid { grid-template-columns: repeat(2,1fr); } }
    @media(min-width:1024px){ .services-grid { grid-template-columns: repeat(3,1fr); } }

    .service-card {
      position: relative; height: 340px; border-radius: 12px;
      overflow: hidden; cursor: pointer; box-shadow: var(--shadow-card);
    }
    .service-card-bg {
      position: absolute; inset: 0; width: 100%; height: 100%;
      object-fit: cover; object-position: center;
      transition: transform 0.5s cubic-bezier(0.25,0.46,0.45,0.94);
    }
    .service-card:hover .service-card-bg { transform: scale(1.06); }
    .service-card-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(11,30,60,0.93) 0%, rgba(27,114,190,0.50) 60%, rgba(27,114,190,0.08) 100%);
    }
    .service-card-content { position: absolute; bottom: 0; left: 0; right: 0; padding: 28px 24px; }
    .service-card-icon {
      width: 48px; height: 48px; background: var(--blue); border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 12px; box-shadow: 0 4px 12px rgba(27,114,190,0.30);
    }
    .service-card-icon svg { width: 24px; height: 24px; stroke: #fff; fill: none; }
    .service-card-content h3 {
      font-size: 24px; font-weight: 700; color: var(--white);
      letter-spacing: -0.02em; margin-bottom: 6px;
    }
    .service-card-content p { font-size: 16px; color: #d1d5db; line-height: 1.5; margin-bottom: 14px; }
    .service-learn-more {
      display: inline-flex; align-items: center; gap: 6px;
      color: var(--blue); font-size: 15px; font-weight: 700;
      text-decoration: none; transition: gap 0.2s;
    }
    .service-card:hover .service-learn-more { gap: 10px; }

    /* ══════════════════════════════════
       PHOTO GALLERY SECTIONS (shared)
    ══════════════════════════════════ */
    .photo-section {
      padding: 100px 24px;
      position: relative;
    }
    .photo-section.dark { background: var(--navy); }
    .photo-section.light { background: #f0f6ff; }
    .photo-section.white-bg { background: #fff; }
    .photo-section-inner { max-width: 1280px; margin: 0 auto; }

    .photo-grid-5 {
      display: grid;
      grid-template-columns: repeat(2,1fr);
      gap: 14px;
    }
    @media(min-width:640px){ .photo-grid-5 { grid-template-columns: repeat(3,1fr); } }
    @media(min-width:1024px){ .photo-grid-5 { grid-template-columns: repeat(5,1fr); } }

    .photo-grid-4 {
      display: grid;
      grid-template-columns: repeat(2,1fr);
      gap: 14px;
    }
    @media(min-width:768px){ .photo-grid-4 { grid-template-columns: repeat(4,1fr); } }

    .photo-grid-3 {
      display: grid;
      grid-template-columns: 1fr;
      gap: 14px;
    }
    @media(min-width:640px){ .photo-grid-3 { grid-template-columns: repeat(2,1fr); } }
    @media(min-width:1024px){ .photo-grid-3 { grid-template-columns: repeat(3,1fr); } }

    .photo-item {
      position: relative; aspect-ratio: 4/3; overflow: hidden;
      border-radius: 10px; background: #d0e4f5;
      box-shadow: 0 2px 12px rgba(27,114,190,0.12);
    }
    .photo-item.tall { aspect-ratio: 3/4; }
    .photo-item img {
      width: 100%; height: 100%; object-fit: cover; display: block;
      transition: transform 0.45s cubic-bezier(0.25,0.46,0.45,0.94);
    }
    .photo-item:hover img { transform: scale(1.05); }
    .photo-item-label {
      position: absolute; bottom: 0; left: 0; right: 0;
      padding: 28px 14px 12px;
      background: linear-gradient(to top, rgba(11,30,60,0.88), transparent);
      font-size: 13px; font-weight: 700; color: #fff;
      letter-spacing: 0.05em; text-transform: uppercase;
      opacity: 0; transition: opacity 0.3s;
    }
    .photo-item:hover .photo-item-label { opacity: 1; }

    /* Horizontal scroll gallery */
    .scroll-gallery-wrap {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      margin-top: 48px;
      padding-bottom: 8px;
    }
    .scroll-gallery-wrap::-webkit-scrollbar { display: none; }
    .scroll-gallery-track {
      display: flex; gap: 16px;
      width: max-content;
    }
    .scroll-gallery-track .photo-item {
      width: 320px; height: 240px;
      aspect-ratio: unset; flex-shrink: 0;
    }
    .scroll-gallery-track .photo-item.tall {
      height: 380px;
    }

    /* ══════════════════════════════════
       WHY CHOOSE US
    ══════════════════════════════════ */
    #why {
      padding: 100px 24px;
      background: var(--navy);
      position: relative;
    }
    .why-inner {
      max-width: 1280px; margin: 0 auto;
      display: grid; grid-template-columns: 1fr; gap: 56px; align-items: start;
    }
    @media(min-width:1024px){ .why-inner { grid-template-columns: 1fr 1fr; } }
    .why-below { max-width: 1280px; margin: 52px auto 0; text-align: center; }
    #why .section-label { color: #60a5fa; }
    #why .section-sub { color: #94a3b8; }

    .why-list { list-style: none; display: flex; flex-direction: column; gap: 20px; margin-top: 32px; }
    .why-list-item { display: flex; align-items: flex-start; gap: 16px; }
    .why-check {
      width: 30px; height: 30px; background: var(--blue); border-radius: 50%;
      display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px;
    }
    .why-check svg { width: 15px; height: 15px; stroke: #fff; fill: none; stroke-width: 2.5; }
    .why-list-item strong { font-size: 19px; font-weight: 700; color: var(--white); display: block; letter-spacing: -0.01em; }
    .why-list-item span { font-size: 16px; color: #94a3b8; line-height: 1.6; }

    .why-image { position: relative; border-radius: 16px; overflow: hidden; }
    .why-image-main { width: 100%; height: 560px; object-fit: cover; display: block; }
    .why-avatar-wrap {
      position: absolute; bottom: 24px; left: 24px;
      display: flex; align-items: flex-end; gap: 12px;
    }
    .why-avatar {
      width: 90px; height: 90px; border-radius: 50%; border: 3px solid #fff;
      object-fit: cover; box-shadow: 0 6px 20px rgba(0,0,0,0.35);
      display: block; background: var(--blue); flex-shrink: 0;
    }
    .why-image-badge {
      background: var(--blue); color: #fff; border-radius: 10px;
      padding: 12px 16px; box-shadow: 0 8px 24px rgba(27,114,190,0.40); margin-bottom: 4px;
    }
    .why-image-badge .num { font-size: 32px; font-weight: 800; letter-spacing: -0.03em; line-height: 1; }
    .why-image-badge .label { font-size: 12px; font-weight: 600; opacity: 0.9; letter-spacing: 0.05em; }

    /* Circle photos - three across, full-width row below section */
    .why-circles {
      display: flex; gap: 28px; justify-content: center; flex-wrap: wrap;
    }
    .why-circle {
      width: 200px; height: 200px; border-radius: 50%; object-fit: cover;
      border: 4px solid var(--blue);
      box-shadow: 0 6px 28px rgba(0,0,0,0.35);
      flex-shrink: 0;
    }
    .why-circle:nth-child(2) { border-color: var(--red); }
    .why-circle:nth-child(3) { border-color: var(--gold); }

    /* Luxury bathroom grid */
    .luxury-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: 220px 220px 220px;
      gap: 14px;
      margin-top: 48px;
    }
    .luxury-grid .photo-item { aspect-ratio: unset; overflow:hidden; border-radius:10px; background:#1a2a4a; }
    .luxury-grid .photo-item img { width:100%; height:100%; object-fit:cover; display:block; }
    /* Col1: short r1, tall r2-3 */
    .luxury-grid .lx-c1r1 { grid-column:1; grid-row:1; }
    .luxury-grid .lx-c1r23 { grid-column:1; grid-row:2/4; }
    /* Col2: tall r1-2, short r3 */
    .luxury-grid .lx-c2r12 { grid-column:2; grid-row:1/3; }
    .luxury-grid .lx-c2r3  { grid-column:2; grid-row:3; }
    /* Col3: short r1, tall r2-3 */
    .luxury-grid .lx-c3r1  { grid-column:3; grid-row:1; }
    .luxury-grid .lx-c3r23 { grid-column:3; grid-row:2/4; }
    /* Col4: tall r1-2, short r3 */
    .luxury-grid .lx-c4r12 { grid-column:4; grid-row:1/3; }
    .luxury-grid .lx-c4r3  { grid-column:4; grid-row:3; }
    @media(max-width:768px) {
      .luxury-grid { grid-template-columns: repeat(2,1fr); grid-template-rows: none; grid-auto-rows:180px; }
      .luxury-grid [class*="lx-"] { grid-column:unset; grid-row:unset; }
      .luxury-grid .lx-c2r12, .luxury-grid .lx-c4r12, .luxury-grid .lx-c1r23, .luxury-grid .lx-c3r23 { grid-row: span 2; }
    }

    /* Water filtration partner section */
    #filtration { padding: 100px 24px; background: #f0f6ff; }
    .filtration-inner { max-width: 1280px; margin: 0 auto; display: grid; grid-template-columns: 1fr; gap: 60px; align-items: center; }
    @media(min-width:1024px){ .filtration-inner { grid-template-columns: 1fr 1fr; } }
    .filtration-text { }
    .filtration-logo-row { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; margin: 32px 0; }
    .filtration-logo-box { background: #fff; border: 1px solid #dde6f5; border-radius: 12px; display: flex; align-items: center; justify-content: center; overflow: hidden; }
    .filtration-logo-box.logo-to { padding: 0 16px; height: 72px; width: 180px; }
    .filtration-logo-box.logo-to img { width: 160px; height: 160px; object-fit: contain; display: block; }
    .filtration-logo-box.logo-ffy { padding: 14px 20px; }
    .filtration-logo-box.logo-ffy img { height: 44px; width: auto; display: block; }
    .filtration-plus { font-size: 28px; font-weight: 300; color: #94a3b8; line-height: 1; flex-shrink: 0; }
    .filtration-pills { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 28px; }
    .filtration-pill { background: #fff; border: 1px solid #dde6f5; border-radius: 999px; padding: 8px 18px; font-size: 14px; font-weight: 600; color: var(--blue); }
    .filtration-photos { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .filtration-photos .photo-item { aspect-ratio: unset; height: 220px; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.10); }
    .filtration-photos .photo-item img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .filtration-photos .photo-item-label { font-size: 12px; font-weight: 600; }
    .filtration-btns { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 32px; }

    /* Why section collage */
    .why-image { align-self: start; }
    .why-collage {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .why-collage-row { display: flex; gap: 10px; }
    .why-collage-row.single img { height: 260px; }
    .why-collage-row:not(.single) img { height: 185px; }
    .why-collage-img {
      width: 100%; object-fit: cover; border-radius: 10px;
      box-shadow: 0 4px 16px rgba(0,0,0,0.25);
      display: block; flex: 1; min-width: 0;
    }

    /* ══════════════════════════════════
       GUARANTEES
    ══════════════════════════════════ */
    #guarantees { background: var(--navy); padding: 100px 24px; }
    .guarantees-inner { max-width: 1280px; margin: 0 auto; }
    .guarantees-grid {
      display: grid; grid-template-columns: repeat(2,1fr); gap: 24px; margin-top: 52px;
    }
    @media(min-width:1024px){ .guarantees-grid { grid-template-columns: repeat(4,1fr); } }
    .guarantee-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.09);
      border-top: 3px solid var(--blue);
      border-radius: 14px; padding: 40px 28px 36px; text-align: center;
      transition: background 0.2s, border-color 0.2s, transform 0.2s;
      position: relative;
    }
    .guarantee-card:hover {
      background: rgba(11,97,244,0.10); border-color: rgba(11,97,244,0.45); border-top-color: var(--blue); transform: translateY(-4px);
    }
    .guarantee-icon-wrap {
      width: 76px; height: 76px; border-radius: 50%;
      background: rgba(11,97,244,0.15);
      border: 1.5px solid rgba(11,97,244,0.35);
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 24px;
    }
    .guarantee-icon-wrap svg { width: 36px; height: 36px; stroke: var(--blue); fill: none; stroke-width: 1.6; stroke-linecap: round; stroke-linejoin: round; }
    .guarantee-card h3 { font-size: 20px; font-weight: 700; color: var(--white); letter-spacing: -0.01em; margin-bottom: 12px; }
    .guarantee-card p { font-size: 15px; color: #94a3b8; line-height: 1.7; }

    /* ══════════════════════════════════
       REVIEWS
    ══════════════════════════════════ */
    #reviews { padding: 100px 24px; background: #f0f6ff; }
    .reviews-inner { max-width: 1280px; margin: 0 auto; }
    /* Reviews infinite scroll strip */
    .reviews-scroll-outer { overflow: hidden; margin-top: 52px; position: relative; }
    .reviews-scroll-outer::before, .reviews-scroll-outer::after {
      content:''; position:absolute; top:0; bottom:0; width:140px; z-index:2; pointer-events:none;
    }
    .reviews-scroll-outer::before { left:0; background:linear-gradient(to right,#f0f6ff,transparent); }
    .reviews-scroll-outer::after  { right:0; background:linear-gradient(to left,#f0f6ff,transparent); }
    .reviews-scroll-track {
      display: flex; gap: 20px;
      animation: reviewsScroll 60s linear infinite;
      width: max-content;
    }
    .reviews-scroll-outer:hover .reviews-scroll-track { animation-play-state: paused; }
    @keyframes reviewsScroll { 0% { transform:translateX(0); } 100% { transform:translateX(-50%); } }

    .review-card {
      width: 340px; flex-shrink: 0;
      background: #fff; border-radius: 14px; padding: 24px;
      box-shadow: 0 2px 16px rgba(27,114,190,0.09);
      border: 1px solid #e2e8f0; border-top: 3px solid var(--blue);
    }
    .review-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; }
    .review-stars { color:var(--gold); font-size:15px; letter-spacing:2px; }
    .google-badge { display:flex; align-items:center; gap:5px; font-size:12px; font-weight:700; color:var(--text-muted); }
    .google-g {
      width:20px; height:20px;
      background:linear-gradient(135deg,#4285f4 25%,#ea4335 25% 50%,#fbbc04 50% 75%,#34a853 75%);
      border-radius:50%; display:flex; align-items:center; justify-content:center;
    }
    .google-g span { font-size:11px; font-weight:800; color:#fff; }
    .review-text { font-size:15px; color:#374151; line-height:1.68; font-style:italic; margin-bottom:18px; }
    .review-author { display:flex; align-items:center; gap:10px; }
    .review-avatar {
      width:38px; height:38px; border-radius:50%; flex-shrink:0;
      display:flex; align-items:center; justify-content:center;
      font-size:15px; font-weight:700; color:#fff;
    }
    .review-author-info strong { display:block; font-size:15px; font-weight:700; color:var(--navy); }
    .review-author-info span { font-size:13px; color:var(--text-muted); }
    /* carousel controls hidden */
    .carousel-controls { display:none; }
    .carousel-dot { display:none; }

    /* ══════════════════════════════════
       PORTFOLIO / GALLERY
    ══════════════════════════════════ */
    #gallery { padding: 100px 0; background: #fff; position: relative; overflow: hidden; }
    .portfolio-inner { max-width: 1280px; margin: 0 auto; padding: 0 24px; }
    .gallery-scroll-wrap { margin-top: 52px; overflow: hidden; position: relative; }
    .gallery-scroll-wrap::before, .gallery-scroll-wrap::after {
      content: ''; position: absolute; top: 0; bottom: 0; width: 100px; z-index: 2; pointer-events: none;
    }
    .gallery-scroll-wrap::before { left: 0; background: linear-gradient(to right, #fff, transparent); }
    .gallery-scroll-wrap::after { right: 0; background: linear-gradient(to left, #fff, transparent); }
    .gallery-scroll-track {
      display: flex; gap: 16px;
      animation: galleryScroll 70s linear infinite;
      width: max-content;
    }
    .gallery-scroll-wrap:hover .gallery-scroll-track { animation-play-state: paused; }
    @keyframes galleryScroll {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .gallery-scroll-item {
      width: 280px; height: 210px; flex-shrink: 0;
      border-radius: 12px; overflow: hidden;
      box-shadow: 0 4px 16px rgba(27,114,190,0.12);
      position: relative;
    }
    .gallery-scroll-item img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s; }
    .gallery-scroll-item:hover img { transform: scale(1.05); }
    /* Legacy portfolio-item still used in old code - keep for fallback */
    .portfolio-item {
      position: relative; aspect-ratio: 4/3; overflow: hidden; border-radius: 12px;
      background: #d0e4f5; box-shadow: 0 2px 12px rgba(27,114,190,0.10);
    }
    .portfolio-item img {
      width: 100%; height: 100%; object-fit: cover; display: block;
      transition: transform 0.45s cubic-bezier(0.25,0.46,0.45,0.94);
    }
    .portfolio-item:hover img { transform: scale(1.04); }
    .portfolio-item-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(11,30,60,0.80) 0%, transparent 60%);
      opacity: 0; transition: opacity 0.3s; display: flex;
      align-items: flex-end; padding: 14px 16px;
    }
    .portfolio-item:hover .portfolio-item-overlay { opacity: 1; }
    .portfolio-item-overlay span { font-size: 12px; font-weight: 700; color: #fff; letter-spacing: 0.06em; text-transform: uppercase; }
    .btn-view-all {
      display: inline-block; margin-top: 44px; padding: 16px 40px;
      border: 2px solid var(--blue); border-radius: 8px; color: var(--blue);
      font-family: 'Plus Jakarta Sans', sans-serif; font-size: 17px; font-weight: 700;
      text-decoration: none; letter-spacing: -0.01em;
      transition: background 0.2s, color 0.2s, transform 0.15s, box-shadow 0.2s;
    }
    .btn-view-all:hover { background: var(--blue); color: #fff; transform: translateY(-2px); box-shadow: 0 6px 24px rgba(27,114,190,0.28); }

    /* ══════════════════════════════════
       SERVICE AREAS
    ══════════════════════════════════ */
    #areas { padding: 88px 24px; background: var(--blue); }
    .areas-inner { max-width: 1280px; margin: 0 auto; text-align: center; }
    #areas .section-label { color: rgba(255,255,255,0.80); }
    .areas-pills { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; margin-top: 32px; }
    .area-pill {
      background: rgba(255,255,255,0.12); border: 2px solid rgba(255,255,255,0.35);
      border-radius: 50px; padding: 11px 22px; font-size: 16px; font-weight: 600;
      color: #fff; text-decoration: none; cursor: pointer;
      transition: background 0.2s, border-color 0.2s, transform 0.15s;
    }
    .area-pill:hover { background: rgba(255,255,255,0.28); border-color: rgba(255,255,255,0.70); transform: translateY(-2px); }

    /* ══════════════════════════════════
       CONTACT
    ══════════════════════════════════ */
    #contact { background: var(--navy); padding: 100px 24px; }
    .contact-inner {
      max-width: 1280px; margin: 0 auto;
      display: grid; grid-template-columns: 1fr; gap: 56px; align-items: start;
    }
    @media(min-width:1024px){ .contact-inner { grid-template-columns: 1fr 480px; } }
    .contact-info h2 {
      font-size: clamp(36px, 5vw, 60px); font-weight: 800; color: var(--white);
      letter-spacing: -0.03em; line-height: 1.05; margin-bottom: 20px;
    }
    .contact-info p { font-size: 18px; color: #9ca3af; line-height: 1.7; margin-bottom: 36px; }
    .contact-details { display: flex; flex-direction: column; gap: 18px; }
    .contact-detail-item { display: flex; align-items: center; gap: 16px; }
    .contact-detail-icon {
      width: 48px; height: 48px; background: rgba(27,114,190,0.15);
      border: 1px solid rgba(27,114,190,0.30); border-radius: 10px;
      display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .contact-detail-icon svg { width: 22px; height: 22px; stroke: var(--blue); fill: none; }
    .contact-detail-item strong { display: block; font-size: 16px; font-weight: 700; color: var(--white); }
    .contact-detail-item a { font-size: 15px; color: #9ca3af; text-decoration: none; transition: color 0.2s; }
    .contact-detail-item a:hover { color: var(--blue); }
    .contact-form-card {
      background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
      border-radius: 16px; padding: 40px 36px;
    }
    .contact-form-card h3 { font-size: 24px; font-weight: 700; color: var(--white); margin-bottom: 24px; letter-spacing: -0.02em; }
    .contact-form-card .form-group label { color: #9ca3af; }
    .contact-form-card .form-group input,
    .contact-form-card .form-group select,
    .contact-form-card .form-group textarea {
      background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.12); color: var(--white);
    }
    .contact-form-card .form-group input::placeholder,
    .contact-form-card .form-group textarea::placeholder { color: #6b7280; }
    .contact-form-card .form-group input:focus,
    .contact-form-card .form-group select:focus,
    .contact-form-card .form-group textarea:focus {
      border-color: var(--blue); background: rgba(27,114,190,0.08);
    }
    .contact-form-card .form-group select option { background: #1a1a1a; color: #fff; }

    /* ══════════════════════════════════
       FOOTER
    ══════════════════════════════════ */
    footer { background: var(--navy2); border-top: 1px solid #1a3060; padding: 64px 24px 36px; }
    .footer-inner { max-width: 1280px; margin: 0 auto; }
    .footer-top {
      display: grid; grid-template-columns: 1fr; gap: 40px; margin-bottom: 52px;
    }
    @media(min-width:768px){ .footer-top { grid-template-columns: 1fr 1fr 1fr; } }
    @media(min-width:1024px){ .footer-top { grid-template-columns: 2fr 1fr 1fr; } }
    .footer-brand img { height: 60px; width: auto; margin-bottom: 18px; display: block; }
    .footer-brand p { font-size: 15px; color: #6b7280; line-height: 1.7; margin-bottom: 12px; }
    .footer-brand .lic { font-size: 14px; color: #4b5563; }
    .footer-col h4 {
      font-size: 14px; font-weight: 700; color: var(--white);
      letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 18px;
    }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }
    .footer-col ul li a { font-size: 15px; color: #6b7280; text-decoration: none; transition: color 0.2s; }
    .footer-col ul li a:hover { color: var(--blue); }
    .footer-bottom {
      border-top: 1px solid #1a3060; padding-top: 28px;
      display: flex; flex-direction: column; gap: 8px; align-items: center; text-align: center;
    }
    @media(min-width:768px){ .footer-bottom { flex-direction: row; justify-content: space-between; text-align: left; } }
    .footer-bottom p { font-size: 14px; color: #4b5563; }
    .footer-bottom .blue { color: var(--blue); }

    /* ══════════════════════════════════
       ANIMATIONS
    ══════════════════════════════════ */
    .fade-up { opacity: 0; transform: translateY(24px); transition: opacity 0.55s ease, transform 0.55s ease; }
    .fade-up.visible { opacity: 1; transform: translateY(0); }

    .sr-only { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0,0,0,0); }
  </style>
</head>
<body>

<!-- ══════════════════════════════════════════
     TWO-TONE STICKY NAV
══════════════════════════════════════════ -->
<nav id="navbar" role="navigation" aria-label="Main navigation">

  <!-- Top bar: dark navy with logo + phone -->
  <div class="nav-top">
    <div class="nav-top-inner">
      <a href="/" class="nav-logo" aria-label="Tapped Out Plumbing Services - Home">
        <img src="assets/logos/tapped-out-logo-text-only.png" alt="Tapped Out Plumbing Services">
      </a>
      <div class="nav-top-right">
        <a href="tel:0434025412" class="nav-phone-top" aria-label="Call 0434 025 412">
          <span class="nav-phone-icon"><i class="fa-solid fa-phone"></i></span>
          <span class="nav-phone-num">0434 025 412</span>
        </a>
        <a href="#hero-form" class="btn-quote-top">Get Free Quote</a>
        <button id="hamburger" aria-label="Toggle mobile menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" role="region" aria-label="Mobile navigation">
    <ul role="list">
      <li><a href="#services">Services</a></li>
      <li><a href="#luxury">Home Fitouts</a></li>
      <li><a href="#why">About</a></li>
      <li><a href="#guarantees">Guarantees</a></li>
      <li><a href="#reviews">Reviews</a></li>
      <li><a href="#gallery">Gallery</a></li>
      <li><a href="#areas">Service Areas</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
  </div>
</nav>

  <!-- Bottom bar: blue with nav links -->
  <div class="nav-bottom">
    <div class="nav-bottom-inner">
      <ul class="nav-links" role="list">
        <li><a href="#services">Services</a></li>
        <li><a href="#hotwater">Hot Water</a></li>
        <li><a href="#luxury">Home Fitouts</a></li>
        <li><a href="#tapware">Tapware</a></li>
        <li><a href="#filtration">Filtered Water</a></li>
        <li><a href="#why">About</a></li>
        <li><a href="#gallery">Gallery</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
      <span class="nav-tagline">Licensed · Bondi Beach &amp; Eastern Suburbs</span>
    </div>
  </div>


<!-- ══════════════════════════════════════════
     HERO
══════════════════════════════════════════ -->
<section id="hero" aria-label="Hero section">
  <div class="hero-bg" role="img" aria-label="Licensed plumber Bondi Beach Eastern Suburbs Sydney">
    <img class="hero-bg-img" src="assets/photos/jean-paul/IMG_7994.JPG" alt="Jean-Paul licensed plumber Bondi Beach Eastern Suburbs Sydney">
    <img class="hero-bg-img" src="assets/photos/jean-paul/IMG_7493.jpeg" alt="Tapped Out Plumbing Services Eastern Suburbs Sydney">
