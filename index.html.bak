<!-- ══════════════════════════════════════════
     JAVASCRIPT
══════════════════════════════════════════ -->
<script>
(function() {
  'use strict';

  /* ── NAVBAR SCROLL ── */
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    navbar.classList.toggle('scrolled', window.scrollY > 20);
  }, { passive: true });

  /* ── HAMBURGER ── */
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobile-menu');
  hamburger.addEventListener('click', () => {
    const isOpen = hamburger.classList.toggle('open');
    mobileMenu.classList.toggle('open', isOpen);
    hamburger.setAttribute('aria-expanded', String(isOpen));
  });
  mobileMenu.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      hamburger.classList.remove('open');
      mobileMenu.classList.remove('open');
      hamburger.setAttribute('aria-expanded', 'false');
    });
  });

  /* ── REVIEW READ MORE ── */
  window.toggleReview = function(btn) {
    const text = btn.previousElementSibling;
    const expanded = text.classList.toggle('expanded');
    btn.textContent = expanded ? 'Show less ↑' : 'Read more ↓';
  };

  /* ── REVIEWS CAROUSEL (now CSS infinite scroll, no JS needed) ── */
  /* (function() {  // disabled */
  if (false) (function() {
    const track = document.getElementById('reviewsTrack');
    const realSlides = Array.from(track.querySelectorAll('.review-slide'));
    const total = realSlides.length;
    let autoAdvanceTimer = null;
    let isTransitioning = false;
    let spv = 4;
    let currentPos = 0;

    function getSPV() {
      if (window.innerWidth >= 1024) return 4;
      if (window.innerWidth >= 768) return 2;
      return 1;
    }

    function buildClones() {
      track.innerHTML = '';
      // Append clones of last N slides at the start (for going left)
      for (let i = total - spv; i < total; i++) {
        const cl = realSlides[i].cloneNode(true);
        cl.setAttribute('aria-hidden','true');
        cl.style.minWidth = (100 / spv) + '%';
        track.appendChild(cl);
      }
      // Real slides
      realSlides.forEach(s => {
        s.style.minWidth = (100 / spv) + '%';
        track.appendChild(s);
      });
      // Clones of first N slides at the end (for going right)
      for (let i = 0; i < spv; i++) {
        const cl = realSlides[i].cloneNode(true);
        cl.setAttribute('aria-hidden','true');
        cl.style.minWidth = (100 / spv) + '%';
        track.appendChild(cl);
      }
    }

    function getTranslate(pos) {
      // pos 0 = first real slide = index spv in the track
      return ((spv + pos) / (total + spv * 2)) * 100;
    }

    function jumpTo(pos, animated) {
      track.style.transition = animated ? 'transform 0.45s cubic-bezier(0.25,0.46,0.45,0.94)' : 'none';
      track.style.transform = `translateX(-${getTranslate(pos)}%)`;
    }

    function advance(dir) {
      if (isTransitioning) return;
      isTransitioning = true;
      currentPos += dir;
      jumpTo(currentPos, true);
    }

    track.addEventListener('transitionend', () => {
      isTransitioning = false;
      if (currentPos >= total) {
        currentPos -= total;
        track.style.transition = 'none';
        track.style.transform = `translateX(-${getTranslate(currentPos)}%)`;
        track.getBoundingClientRect(); // force reflow
      } else if (currentPos < 0) {
        currentPos += total;
        track.style.transition = 'none';
        track.style.transform = `translateX(-${getTranslate(currentPos)}%)`;
        track.getBoundingClientRect();
      }
    });

    function init() {
      spv = getSPV();
      buildClones();
      jumpTo(currentPos, false);
    }

    document.getElementById('reviewNext').addEventListener('click', () => { resetAuto(); advance(1); });
    document.getElementById('reviewPrev').addEventListener('click', () => { resetAuto(); advance(-1); });

    function startAuto() { autoAdvanceTimer = setInterval(() => advance(1), 5000); }
    function resetAuto() { clearInterval(autoAdvanceTimer); startAuto(); }

    window.addEventListener('resize', () => { init(); }, { passive: true });

    init();
    startAuto();
  })();

  /* ── SCROLL ANIMATIONS ── */
  const fadeEls = document.querySelectorAll('.fade-up');
  if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => { if (entry.isIntersecting) { entry.target.classList.add('visible'); observer.unobserve(entry.target); } });
    }, { threshold: 0, rootMargin: '9999px 0px 9999px 0px' });
    fadeEls.forEach(el => observer.observe(el));
  } else {
    fadeEls.forEach(el => el.classList.add('visible'));
  }

  /* ── GALLERY EXPAND ── */
  function expandGallery() {
    document.querySelectorAll('.gallery-extra').forEach(el => el.style.display = '');
    document.getElementById('viewMoreBtn').style.display = 'none';
  }

  /* ── SMOOTH ANCHOR SCROLL ── */
  document.querySelectorAll('a[href^="#"]').forEach(link => {
    link.addEventListener('click', (e) => {
      const target = document.querySelector(link.getAttribute('href'));
      if (target) {
        e.preventDefault();
        const offset = 145;
        const top = target.getBoundingClientRect().top + window.scrollY - offset;
        window.scrollTo({ top, behavior: 'smooth' });
      }
    });
  });

})();
</script>

</body>
</html>
